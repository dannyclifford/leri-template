{
  "name": "leri-template",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "refs:core": "bash scripts/fetch-all-refs.sh",
    "skills:update": "DISABLE_TELEMETRY=1 npx skills update -p -y",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
